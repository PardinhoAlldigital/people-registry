generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  adminId   String?
  admin     User?    @relation("AdminTeam", fields: [adminId], references: [id], onDelete: Cascade)
  members   User[]   @relation("AdminTeam")
  people    Person[]
  createdAt DateTime @default(now())
}

model Person {
  id                String   @id @default(cuid())
  fullName          String
  cep               String
  street            String
  complement        String   @default("")
  neighborhood      String
  city              String
  state             String
  idNumber          String   @default("")
  phone             String
  hasDenomination   Boolean  @default(false)
  denomination      String?
  acceptsBibleStudy Boolean  @default(false)
  acceptsVisit      Boolean  @default(false)
  howHeard          String   @default("")
  services          String[]
  serviceTickets    Json     @default("{}")
  groupId           String
  createdById       String
  createdBy         User     @relation(fields: [createdById], references: [id])
  createdAt         DateTime @default(now())
}

model Service {
  id        String   @id @default(cuid())
  name      String
  groupId   String
  createdAt DateTime @default(now())

  @@unique([groupId, name])
}
